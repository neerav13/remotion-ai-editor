{
    "name": "remotion-ai-editor",
    "version": "1.0.0",
    "description": "Professional AI-powered video editing workflow with Remotion + Claude Code",
    "private": true,
    "scripts": {
          "dev": "remotion studio",
          "build": "remotion render",
          "render": "node scripts/render.mjs",
          "render:youtube": "node scripts/render.mjs --template youtube",
          "render:shorts": "node scripts/render.mjs --template shorts",
          "render:instagram": "node scripts/render.mjs --template instagram",
          "render:client": "node scripts/render.mjs --template client",
          "preview": "remotion studio",
          "upgrade": "remotion upgrade"
    },
    "dependencies": {
          "@remotion/bundler": "^4.0.0",
          "@remotion/cli": "^4.0.0",
          "@remotion/compositor-linux-x64-gnu": "^4.0.0",
          "@remotion/media-utils": "^4.0.0",
          "@remotion/motion-blur": "^4.0.0",
          "@remotion/noise": "^4.0.0",
          "@remotion/paths": "^4.0.0",
          "@remotion/player": "^4.0.0",
          "@remotion/renderer": "^4.0.0",
          "@remotion/shapes": "^4.0.0",
          "@remotion/tailwind": "^4.0.0",
          "remotion": "^4.0.0"
    },
    "devDependencies": {
          "@types/react": "^18.0.0",
          "autoprefixer": "^10.4.0",
          "postcss": "^8.4.0",
          "tailwindcss": "^3.3.0",
          "typescript": "^5.0.0"
    },
    "remotion": {
          "entryPoint": "./src/index.ts"
    }
